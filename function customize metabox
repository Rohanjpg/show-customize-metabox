/**
 * Hide admin bar in Customizer preview
 */
add_action('after_setup_theme', function() {
    if (is_customize_preview() && isset($_GET['locked']) && $_GET['locked'] === 'true') {
        add_filter('show_admin_bar', '__return_false');
    }
});

/**
 * Keep only the allowed Customizer sections/panels for this template.
 * Must run late: other theme customize_register callbacks are declared below
 * this hook and would otherwise add sections after we strip them.
 */
add_action('customize_register', function($wp_customize) {
    if (empty($_GET['locked']) || $_GET['locked'] !== 'true' || empty($_GET['sections'])) {
        return;
    }

    $raw = sanitize_text_field(wp_unslash($_GET['sections']));
    $allowed = array_filter(array_map('trim', explode(',', $raw)));

    if (empty($allowed)) {
        return;
    }

    foreach ($wp_customize->sections() as $id => $section) {
        if (!in_array($id, $allowed, true)) {
            $wp_customize->remove_section($id);
        }
    }

    foreach ($wp_customize->panels() as $id => $panel) {
        if (!in_array($id, $allowed, true)) {
            $wp_customize->remove_panel($id);
        }
    }

    if (!empty($allowed)) {
        $first_section = $allowed[0];
        add_action('customize_controls_print_footer_scripts', function() use ($first_section) {
            ?>
            <script>
            //wp.customize.section('<?php echo esc_js($first_section); ?>').focus();
            </script>
            <?php
        });
    }
}, PHP_INT_MAX);




