// ------------------------------------------------  this remove home-page  extra metabox ---------------------------------------------//


function mytheme_customize_homepage_metaboxes() {
    global $post;

    // Only for the 'page' post type
    if( get_post_type() !== 'page' ) return;

    // Only for Home Page by slug (replace 'home-page' with your slug)
    $template = get_page_template_slug($post->ID);
    if ( $template !== 'templates/Home_tem.php' && $template !== 'templates/About_tem.php' && $template !== 'templates/Contact_tem.php' && $template !== 'templates/Blog_tem.php' && $template !== 'templates/Success_stories_tem.php' && $template !== 'templates/Solutions_tem.php' && $template !== 'templates/Success_stories.php' && $template !== 'templates/Hire_us_tem.php') return;

    // Keep: Publish & Page Attributes
    // Remove all others
    remove_meta_box('slugdiv', 'page', 'normal');          // Slug
    remove_meta_box('authordiv', 'page', 'normal');        // Author
    remove_meta_box('commentstatusdiv', 'page', 'normal'); // Discussion
    remove_meta_box('commentsdiv', 'page', 'normal');      // Comments
    remove_meta_box('revisionsdiv', 'page', 'normal');     // Revisions
    remove_meta_box('trackbacksdiv', 'page', 'normal');    // Trackbacks
    remove_meta_box('postcustom', 'page', 'normal');       // Custom Fields
    remove_post_type_support('page', 'editor');          // description 
}
add_action('add_meta_boxes', 'mytheme_customize_homepage_metaboxes', 99);














